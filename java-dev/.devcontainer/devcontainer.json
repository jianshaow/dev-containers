{
	"name": "JAVA-DEV",
	"image": "jianshao/java-dev:21",
	"runArgs": [
		"--network=host",
		"--group-add",
		"${localEnv:DOCKER_GID}"
	],
	"mounts": [
		{
			"source": "${localEnv:HOME}/source",
			"target": "/home/ubuntu/source",
			"type": "bind"
		},
		{
			"source": "${localEnv:HOME}/.ssh",
			"target": "/home/ubuntu/.ssh",
			"type": "bind"
		},
		{
			"source": "${localEnv:HOME}/.cache",
			"target": "/home/ubuntu/.cache",
			"type": "bind"
		},
		{
			"source": "${localEnv:HOME}/.m2",
			"target": "/home/ubuntu/.m2",
			"type": "bind"
		},
		{
			"source": "${localEnv:HOME}/.copilot",
			"target": "/home/ubuntu/.copilot",
			"type": "bind"
		},
		{
			"source": "${localEnv:HOME}/.opencode",
			"target": "/home/ubuntu/.opencode",
			"type": "bind"
		},
		{
			"source": "/usr/bin/docker",
			"target": "/usr/bin/docker",
			"type": "bind"
		},
		{
			"source": "/usr/libexec/docker/cli-plugins",
			"target": "/usr/libexec/docker/cli-plugins",
			"type": "bind"
		},
		{
			"source": "/var/run/docker.sock",
			"target": "/var/run/docker.sock",
			"type": "bind"
		}
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"vscjava.vscode-java-pack"
			]
		}
	}
}